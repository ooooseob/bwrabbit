    "MAX_FEATURES":    { "label": "최대 어휘 크기", "hint": "CountVectorizer max_features" },
    "MAX_ITER":        { "label": "LDA 반복 횟수", "hint": "클수록 정확하나 느림" },
    "RANDOM_STATE":    { "label": "랜덤 시드", "hint": "재현성 보장. 기본 42" },
    "OUTPUT_FILENAME": { "label": "리포트 파일명", "hint": "_company/reports/ 에 저장" },
    "OUTPUT_CSV":      { "label": "결과 CSV", "hint": "_company/data/ 에 저장. dominant_topic 컬럼 추가" }
